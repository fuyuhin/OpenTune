<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="horizontal"
    android:padding="10dp"
    android:gravity="center_vertical">

    <!--
        Square album art: fixed 84dp so it matches the inner height of a 4×2 widget
        (110dp outer - 2×10dp padding = 90dp, 84dp leaves a little breathing room).
        Rounded corners (12dp) are applied to the loaded bitmap programmatically;
        the background provides a fallback rounded rect when no art is loaded.
        android:tint is intentionally absent — colour filters applied in code.
    -->
    <ImageView
        android:id="@+id/widget_album_art"
        android:layout_width="84dp"
        android:layout_height="84dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_music_placeholder"
        android:background="@drawable/widget_art_background" />

    <!-- Right column: title / artist / album / controls -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="10dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_song_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/not_playing"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_artist_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#CCFFFFFF"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="1dp" />

        <TextView
            android:id="@+id/widget_album_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#99FFFFFF"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="1dp" />

        <!--
            Controls: 5 FrameLayouts with equal weight so buttons spread evenly.
            Play button is larger (40dp) and overflows its slot visually;
            prev/next/like/repeat use 26dp icons centred in their slots.
            <View> is NOT in the RemoteViews supported-view list — FrameLayout IS.
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <!-- Like / Favourite -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <ImageButton
                    android:id="@+id/widget_btn_like"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:src="@drawable/favorite_border"
                    android:background="@android:color/transparent"
                    android:scaleType="fitCenter" />
            </FrameLayout>

            <!-- Previous track -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <ImageButton
                    android:id="@+id/widget_btn_prev"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_widget_prev"
                    android:background="@android:color/transparent"
                    android:scaleType="fitCenter" />
            </FrameLayout>

            <!-- Play / Pause (larger, intentionally overflows slot) -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <ImageButton
                    android:id="@+id/widget_btn_play_pause"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_play_white"
                    android:background="@drawable/widget_play_button_bg"
                    android:scaleType="fitCenter" />
            </FrameLayout>

            <!-- Next track -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <ImageButton
                    android:id="@+id/widget_btn_next"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_widget_next"
                    android:background="@android:color/transparent"
                    android:scaleType="fitCenter" />
            </FrameLayout>

            <!-- Repeat mode -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <ImageButton
                    android:id="@+id/widget_btn_repeat"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:src="@drawable/repeat"
                    android:background="@android:color/transparent"
                    android:scaleType="fitCenter" />
            </FrameLayout>

        </LinearLayout>

    </LinearLayout>
</LinearLayout>
