<?xml version="1.0" encoding="utf-8"?>
<!--
    Spec: dark-glass surface. Row 1 = square album art (left) + text column
    (right). Row 2 = full-width transport bar spanning both columns. Five flat
    pure-white controls, no backgrounds: heart · prev · play|pause · next · repeat.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="10dp">

    <!--
        Row 1: art + text. Weighted (height 0 / weight 1) so the transport bar
        keeps a fixed 44dp. Art width is set at runtime to equal this row's
        height (API 31+) so it stays a perfect square at any widget height.
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/widget_album_art"
            android:layout_width="118dp"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="@drawable/widget_art_background" />

        <!-- Text column; 12dp column-gap from the art. -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_song_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/not_playing"
                android:textColor="#FFFFFFFF"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:lineSpacingMultiplier="1.14"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_artist_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="#D1FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_album_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#A8FFFFFF"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_lyrics"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="#A8FFFFFF"
                android:textSize="11sp"
                android:textStyle="italic"
                android:lineSpacingMultiplier="1.32"
                android:maxLines="2"
                android:ellipsize="end"
                android:visibility="gone" />

        </LinearLayout>
    </LinearLayout>

    <!--
        Row 2: full-width transport bar (6dp row-gap above). Five equal slots.
        Each button is a 44dp hit target; transparent padding shrinks the visible
        glyph to 28dp (secondary) / 40dp (primary play-pause).
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="6dp"
        android:orientation="horizontal">

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <ImageButton
                android:id="@+id/widget_btn_like"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:padding="8dp"
                android:src="@drawable/favorite_border"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:scaleType="fitCenter"
                android:contentDescription="@string/action_like" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <ImageButton
                android:id="@+id/widget_btn_prev"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:padding="8dp"
                android:src="@drawable/ic_widget_prev"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:scaleType="fitCenter"
                android:contentDescription="@string/previous" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <ImageButton
                android:id="@+id/widget_btn_play_pause"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:padding="2dp"
                android:src="@drawable/ic_play_white"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:scaleType="fitCenter"
                android:contentDescription="@string/play" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <ImageButton
                android:id="@+id/widget_btn_next"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:padding="8dp"
                android:src="@drawable/ic_widget_next"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:scaleType="fitCenter"
                android:contentDescription="@string/next" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <ImageButton
                android:id="@+id/widget_btn_repeat"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:padding="8dp"
                android:src="@drawable/repeat"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:scaleType="fitCenter"
                android:contentDescription="@string/repeat_mode_off" />
        </FrameLayout>

    </LinearLayout>
</LinearLayout>
