<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="horizontal"
    android:padding="10dp">

    <!-- Album art: fills widget height, ~35% of width -->
    <ImageView
        android:id="@+id/widget_album_art"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="35"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_music_placeholder"
        android:background="@drawable/widget_art_background"
        android:contentDescription="@string/album_art" />

    <!-- Right column: title, artist, controls -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="65"
        android:orientation="vertical"
        android:layout_marginStart="10dp">

        <!-- Top flexible spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/widget_song_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/not_playing"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_artist_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#B3FFFFFF"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp" />

        <!-- Controls row: buttons spread evenly with flexible spacers -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/widget_btn_prev"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/skip_previous"
                android:background="@android:color/transparent"
                android:tint="#FFFFFFFF"
                android:contentDescription="@string/previous" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/widget_btn_play_pause"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_play_white"
                android:background="@drawable/widget_play_button_bg"
                android:tint="#FF000000"
                android:contentDescription="@string/play_pause" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/widget_btn_next"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/skip_next"
                android:background="@android:color/transparent"
                android:tint="#FFFFFFFF"
                android:contentDescription="@string/next" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

        </LinearLayout>

        <!-- Bottom flexible spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>
</LinearLayout>
