<?xml version="1.0" encoding="utf-8"?>
<!--
    Spec: dark-glass surface, art locked 1:1 left, right column has text top /
    controls bottom with space-between. Five flat controls, all pure white, no
    backgrounds: heart · prev · play|pause · next · shuffle.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="horizontal">

    <!--
        Art fills widget height; width overridden at runtime via setViewLayoutWidth
        on API 31+ so it stays a perfect square at any widget height.
    -->
    <ImageView
        android:id="@+id/widget_album_art"
        android:layout_width="130dp"
        android:layout_height="match_parent"
        android:layout_marginStart="6dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"
        android:scaleType="centerCrop"
        android:background="@drawable/widget_art_background" />

    <!-- Right column: text hugs top, controls hug bottom (space-between). -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:orientation="vertical"
        android:paddingStart="0dp"
        android:paddingEnd="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="6dp">

        <!-- Text stack -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_song_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/not_playing"
                android:textColor="#FFFFFFFF"
                android:textSize="21sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="-0.015"
                android:lineSpacingMultiplier="1.1"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_artist_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:textColor="#D1FFFFFF"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_album_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#A8FFFFFF"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_lyrics"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#A8FFFFFF"
                android:textSize="12sp"
                android:textStyle="italic"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Spring pushes controls to the bottom -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!--
            Controls row: 5 flat icons, equal slots. Hit target 44×44 via
            ImageButton size; transparent padding makes secondary icons
            appear 32dp while keeping the full 44dp tap area.
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <ImageButton
                    android:id="@+id/widget_btn_prev"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:padding="6dp"
                    android:src="@drawable/ic_widget_prev"
                    android:background="@android:color/transparent"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/previous" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <ImageButton
                    android:id="@+id/widget_btn_play_pause"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_play_white"
                    android:background="@android:color/transparent"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/play_pause" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <ImageButton
                    android:id="@+id/widget_btn_next"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:padding="6dp"
                    android:src="@drawable/ic_widget_next"
                    android:background="@android:color/transparent"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/next" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <ImageButton
                    android:id="@+id/widget_btn_repeat"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:padding="6dp"
                    android:src="@drawable/repeat"
                    android:background="@android:color/transparent"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/repeat" />
            </FrameLayout>

        </LinearLayout>

    </LinearLayout>
</LinearLayout>
