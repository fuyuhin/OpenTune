<?xml version="1.0" encoding="utf-8"?>
<!--
    4×1 compact: square art (left) + right column with title on top and the
    transport bar pinned to the bottom (space-between). No artist/album/lyric
    rows — height doesn't allow them.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="horizontal"
    android:padding="8dp">

    <!-- Square art; width set at runtime to match height (API 31+). -->
    <ImageView
        android:id="@+id/widget_album_art"
        android:layout_width="62dp"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:background="@drawable/widget_art_background" />

    <!-- Right column; 10dp column-gap from the art. -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_marginStart="10dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_song_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/not_playing"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Hidden text views kept so the provider can address them generically. -->
        <TextView
            android:id="@+id/widget_artist_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#D1FFFFFF"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:visibility="gone" />

        <TextView
            android:id="@+id/widget_album_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#A8FFFFFF"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:visibility="gone" />

        <TextView
            android:id="@+id/widget_lyrics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#A8FFFFFF"
            android:textSize="10sp"
            android:textStyle="italic"
            android:maxLines="1"
            android:ellipsize="end"
            android:visibility="gone" />

        <!-- Spring pushes the transport bar to the bottom. -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!--
            Compact transport bar: 36dp tall, five equal slots. 32dp hit target;
            transparent padding shrinks the glyph to 24dp (secondary) / 32dp (play).
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <ImageButton
                    android:id="@+id/widget_btn_like"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:padding="4dp"
                    android:src="@drawable/favorite_border"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/action_like" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <ImageButton
                    android:id="@+id/widget_btn_prev"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:padding="4dp"
                    android:src="@drawable/ic_widget_prev"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/previous" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <ImageButton
                    android:id="@+id/widget_btn_play_pause"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_play_white"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/play" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <ImageButton
                    android:id="@+id/widget_btn_next"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:padding="4dp"
                    android:src="@drawable/ic_widget_next"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/next" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <ImageButton
                    android:id="@+id/widget_btn_repeat"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:padding="4dp"
                    android:src="@drawable/repeat"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/repeat_mode_off" />
            </FrameLayout>

        </LinearLayout>

    </LinearLayout>
</LinearLayout>
